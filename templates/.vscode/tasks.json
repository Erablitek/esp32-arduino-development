{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "ESP32: Compile",
      "dependsOn": ["_esp32_compile", "_esp32_export_bin"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    {
      "label": "ESP32: Compile + Upload",
      "dependsOn": ["_esp32_compile", "_esp32_export_bin", "_esp32_upload"],
      "dependsOrder": "sequence",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    {
      "label": "_esp32_compile",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--output-dir", "${workspaceFolder}/build",
        "--fqbn", "FQBN_PLACEHOLDER",
        "--libraries", "${workspaceFolder}/../libraries",
        "${workspaceFolder}"
      ],
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },

    {
      "label": "_esp32_export_bin",
      "type": "shell",
      "command": "cp",
      "args": [
        "${workspaceFolder}/build/SKETCH_NAME.ino.bin",
        "${workspaceFolder}/BIN_NAME_PLACEHOLDER"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-Command",
          "Copy-Item '${workspaceFolder}/build/SKETCH_NAME.ino.bin' '${workspaceFolder}/BIN_NAME_PLACEHOLDER' -Force"
        ]
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },

    {
      "label": "_esp32_upload",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "upload",
        "--fqbn", "FQBN_PLACEHOLDER",
        "--input-dir", "${workspaceFolder}/build",
        "-p", "${input:serialPort}",
        "--verify"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    {
      "label": "ESP32: Monitor Serial",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "monitor",
        "-p", "${input:serialPort}",
        "--config", "baudrate=115200"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },

    {
      "label": "ESP32: List Boards",
      "type": "shell",
      "command": "arduino-cli",
      "args": ["board", "list"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }

  ],
  "inputs": [
    {
      "id": "serialPort",
      "type": "promptString",
      "description": "Serial port (e.g., COM5 on Windows, /dev/ttyUSB0 on Linux, /dev/cu.SLAB_USBtoUART on macOS)",
      "default": "COM5"
    }
  ]
}
